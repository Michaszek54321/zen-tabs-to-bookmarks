{
  "manifest_version": 2,
  "name": "Zen Autosave Session",
  "version": "5.1",
  "description": "Automatically saves your open tabs as bookmarks, keeping only the most recent save.",

  "permissions": [
    "tabs",
    "bookmarks",
    "tabGroups",
    "storage"
  ],

  "background": {
    "scripts": ["background.js"]
  },
  
  "browser_action": {
    "default_title": "Save session"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "applications": {
    "gecko": {
      "id": "zen-autosave@local"
    }
  }
}