{
  "manifest_version": 2,
  "name": "Zen Autosave Session",
  "version": "5.1",

  "permissions": [
    "tabs",
    "bookmarks",
    "tabGroups",
    "storage"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "applications": {
    "gecko": {
      "id": "zen-autosave@local"
    }
  }
}