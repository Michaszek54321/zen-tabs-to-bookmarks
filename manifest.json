{
  "manifest_version": 2,
  "name": "Zen Autosave Session",
  "version": "4.0",
  "description": "Stable autosave of Zen/Firefox tabs into structured bookmarks.",

  "permissions": [
    "tabs",
    "bookmarks",
    "tabGroups"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "browser_action": {
    "default_title": "Save session"
  },

  "applications": {
    "gecko": {
      "id": "zen-autosave@local"
    }
  }
}