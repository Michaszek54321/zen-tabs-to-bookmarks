{
  "manifest_version": 2,
  "name": "Zen Session Autosave",
  "version": "2.0",
  "permissions": [
    "tabs",
    "tabGroups",
    "bookmarks",
    "sessions"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_title": "Manual Save"
  },
  "applications": {
    "gecko": {
      "id": "zen-session-autosave@local"
    }
  }
}